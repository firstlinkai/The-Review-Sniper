    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Normalise Facebook reviews into a flat array\nconst reviews = $input.item.json.data || [];\n\nreturn reviews.map(r => ({\n  json: {\n    platform: 'Facebook',\n    reviewId: r.open_graph_story?.id || r.created_time,\n    reviewerName: r.reviewer?.name || 'A Guest',\n    starRating: `${r.rating} STARS`,\n    starRatingNumeric: r.rating || 0,\n    reviewText: r.review_text || '(No written review)',\n    createTime: r.created_time,\n    reviewUrl: `https://www.facebook.com/${$vars.FB_PAGE_ID}/reviews/`\n  }\n}));"
      },
