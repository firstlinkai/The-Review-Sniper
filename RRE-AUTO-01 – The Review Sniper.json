    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Normalise Google reviews into a flat array\nconst reviews = $input.item.json.reviews || [];\n\nreturn reviews.map(r => ({\n  json: {\n    platform: 'Google',\n    reviewId: r.reviewId,\n    reviewerName: r.reviewer?.displayName || 'A Guest',\n    starRating: r.starRating, // ONE TWO THREE FOUR FIVE\n    starRatingNumeric: { 'ONE':1,'TWO':2,'THREE':3,'FOUR':4,'FIVE':5 }[r.starRating] || 0,\n    reviewText: r.comment || '(No written review)',\n    createTime: r.createTime,\n    reviewUrl: `https://search.google.com/local/reviews?placeid=${$vars.GOOGLE_PLACE_ID}`\n  }\n}));"
      },
      "id": "42096cd4-44a6-45b8-851c-6ebb98484aa5",
