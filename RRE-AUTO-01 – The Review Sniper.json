    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse the callback data from Telegram button press\n// Format: ACTION::reviewId::platform\nconst callbackData = $input.item.json.callback_query?.data || '';\nconst parts = callbackData.split('::');\n\nconst action = parts[0] || 'UNKNOWN';\nconst reviewId = parts[1] || '';\nconst platform = parts[2] || '';\nconst callbackQueryId = $input.item.json.callback_query?.id || '';\nconst chatId = $input.item.json.callback_query?.message?.chat?.id || '';\nconst messageId = $input.item.json.callback_query?.message?.message_id || '';\n\n// Extract the AI draft from the original message text\nconst messageText = $input.item.json.callback_query?.message?.text || '';\nconst draftMatch = messageText.match(/AI Draft Reply:[\\s\\S]*?\\n([\\s\\S]*?)\\n---/);\nconst aiDraft = draftMatch ? draftMatch[1].trim() : '';\n\nreturn [{\n  json: {\n    action,\n    reviewId,\n    platform,\n    callbackQueryId,\n    chatId,\n    messageId,\n    aiDraft\n  }\n}];"
      },
      "id": "67007129-59e9-4de5-bbf1-7501c75216e4",
      "name": "Parse Telegram Callback",
